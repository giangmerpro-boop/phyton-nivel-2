@bot.command()
async def mem(ctx):
    # Usa comillas para la carpeta con espacio
    carpeta = "images 2"
    imagenes = os.listdir(carpeta)          # Lista todos los archivos en la carpeta
    imagen = random.choice(imagenes)        # Selecciona uno al azar
    ruta = os.path.join(carpeta, imagen)    # Une la carpeta con el archivo
    with open(ruta, 'rb') as f:
        picture = discord.File(f)
    await ctx.send(file=picture)




